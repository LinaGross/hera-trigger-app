int main()
{
    double z;
    double dz;
    int rc;
    char response[256];
    char dz_str[64];

    WriteFile("E:/Jiayi/NISZBridge/responses/watcher_started.txt", "started", 20);

    if(ExistFile("E:/Jiayi/NISZBridge/commands/current_getz.txt") == 1)
    {
        WriteFile("E:/Jiayi/NISZBridge/responses/found_current_getz.txt", "found current_getz", 50);

        rc = StgGetPosZ(&z, 0);
        if(rc != 1)
        {
            sprintf(response, "ERROR StgGetPosZ failed %d", rc);
            WriteFile("E:/Jiayi/NISZBridge/responses/current_getz_response.txt", response, strlen(response) * 2);
            RenameFile("E:/Jiayi/NISZBridge/commands/current_getz.txt", "E:/Jiayi/NISZBridge/errors/current_getz.txt");
            return rc;
        }

        sprintf(response, "OK %.6f", z);
        WriteFile("E:/Jiayi/NISZBridge/responses/current_getz_response.txt", response, strlen(response) * 2);
        RenameFile("E:/Jiayi/NISZBridge/commands/current_getz.txt", "E:/Jiayi/NISZBridge/processed/current_getz.txt");
        return 1;
    }

    if(ExistFile("E:/Jiayi/NISZBridge/commands/current_move_rel_custom.txt") == 1)
    {
        WriteFile("E:/Jiayi/NISZBridge/responses/found_current_move_rel_custom.txt", "found current_move_rel_custom", 66);

        ReadFile("E:/Jiayi/NISZBridge/commands/current_move_rel_custom.txt", dz_str, 64);
        dz = atof(dz_str);

        rc = StgGetPosZ(&z, 0);
        if(rc != 1)
        {
            sprintf(response, "ERROR StgGetPosZ before MOVE_REL failed %d", rc);
            WriteFile("E:/Jiayi/NISZBridge/responses/current_move_rel_custom_response.txt", response, strlen(response) * 2);
            RenameFile("E:/Jiayi/NISZBridge/commands/current_move_rel_custom.txt", "E:/Jiayi/NISZBridge/errors/current_move_rel_custom.txt");
            return rc;
        }

        rc = StgMoveZ(z + dz, 0);
        if(rc != 1)
        {
            sprintf(response, "ERROR StgMoveZ relative failed %d", rc);
            WriteFile("E:/Jiayi/NISZBridge/responses/current_move_rel_custom_response.txt", response, strlen(response) * 2);
            RenameFile("E:/Jiayi/NISZBridge/commands/current_move_rel_custom.txt", "E:/Jiayi/NISZBridge/errors/current_move_rel_custom.txt");
            return rc;
        }

        rc = StgGetPosZ(&z, 0);
        if(rc != 1)
        {
            sprintf(response, "ERROR StgGetPosZ after MOVE_REL failed %d", rc);
            WriteFile("E:/Jiayi/NISZBridge/responses/current_move_rel_custom_response.txt", response, strlen(response) * 2);
            RenameFile("E:/Jiayi/NISZBridge/commands/current_move_rel_custom.txt", "E:/Jiayi/NISZBridge/errors/current_move_rel_custom.txt");
            return rc;
        }

        sprintf(response, "OK %.6f", z);
        WriteFile("E:/Jiayi/NISZBridge/responses/current_move_rel_custom_response.txt", response, strlen(response) * 2);
        RenameFile("E:/Jiayi/NISZBridge/commands/current_move_rel_custom.txt", "E:/Jiayi/NISZBridge/processed/current_move_rel_custom.txt");
        return 1;
    }

    if(ExistFile("E:/Jiayi/NISZBridge/commands/current_move_abs_4100_4050_7000.txt") == 1)
    {
        WriteFile("E:/Jiayi/NISZBridge/responses/found_current_move_abs_4100_4050_7000.txt", "found current_move_abs_4100", 60);

        rc = StgMoveZ(4100.0, 0);
        if(rc != 1)
        {
            sprintf(response, "ERROR StgMoveZ absolute failed %d", rc);
            WriteFile("E:/Jiayi/NISZBridge/responses/current_move_abs_4100_4050_7000_response.txt", response, strlen(response) * 2);
            RenameFile("E:/Jiayi/NISZBridge/commands/current_move_abs_4100_4050_7000.txt", "E:/Jiayi/NISZBridge/errors/current_move_abs_4100_4050_7000.txt");
            return rc;
        }

        rc = StgGetPosZ(&z, 0);
        if(rc != 1)
        {
            sprintf(response, "ERROR StgGetPosZ after MOVE_ABS failed %d", rc);
            WriteFile("E:/Jiayi/NISZBridge/responses/current_move_abs_4100_4050_7000_response.txt", response, strlen(response) * 2);
            RenameFile("E:/Jiayi/NISZBridge/commands/current_move_abs_4100_4050_7000.txt", "E:/Jiayi/NISZBridge/errors/current_move_abs_4100_4050_7000.txt");
            return rc;
        }

        sprintf(response, "OK %.6f", z);
        WriteFile("E:/Jiayi/NISZBridge/responses/current_move_abs_4100_4050_7000_response.txt", response, strlen(response) * 2);
        RenameFile("E:/Jiayi/NISZBridge/commands/current_move_abs_4100_4050_7000.txt", "E:/Jiayi/NISZBridge/processed/current_move_abs_4100_4050_7000.txt");
        return 1;
    }

    if(ExistFile("E:/Jiayi/NISZBridge/commands/current_move_abs_4200_4000_8100.txt") == 1)
    {
        WriteFile("E:/Jiayi/NISZBridge/responses/found_current_move_abs_4200_4000_8100.txt", "found current_move_abs_4200", 60);

        rc = StgMoveZ(4200.0, 0);
        if(rc != 1)
        {
            sprintf(response, "ERROR StgMoveZ absolute failed %d", rc);
            WriteFile("E:/Jiayi/NISZBridge/responses/current_move_abs_4200_4000_8100_response.txt", response, strlen(response) * 2);
            RenameFile("E:/Jiayi/NISZBridge/commands/current_move_abs_4200_4000_8100.txt", "E:/Jiayi/NISZBridge/errors/current_move_abs_4200_4000_8100.txt");
            return rc;
        }

        rc = StgGetPosZ(&z, 0);
        if(rc != 1)
        {
            sprintf(response, "ERROR StgGetPosZ after MOVE_ABS failed %d", rc);
            WriteFile("E:/Jiayi/NISZBridge/responses/current_move_abs_4200_4000_8100_response.txt", response, strlen(response) * 2);
            RenameFile("E:/Jiayi/NISZBridge/commands/current_move_abs_4200_4000_8100.txt", "E:/Jiayi/NISZBridge/errors/current_move_abs_4200_4000_8100.txt");
            return rc;
        }

        sprintf(response, "OK %.6f", z);
        WriteFile("E:/Jiayi/NISZBridge/responses/current_move_abs_4200_4000_8100_response.txt", response, strlen(response) * 2);
        RenameFile("E:/Jiayi/NISZBridge/commands/current_move_abs_4200_4000_8100.txt", "E:/Jiayi/NISZBridge/processed/current_move_abs_4200_4000_8100.txt");
        return 1;
    }

    if(ExistFile("E:/Jiayi/NISZBridge/commands/current_stop.txt") == 1)
    {
        WriteFile("E:/Jiayi/NISZBridge/responses/found_current_stop.txt", "found current_stop", 40);

        rc = StgGetPosZ(&z, 0);
        if(rc != 1)
        {
            sprintf(response, "ERROR StgGetPosZ failed %d", rc);
            WriteFile("E:/Jiayi/NISZBridge/responses/current_stop_response.txt", response, strlen(response) * 2);
            RenameFile("E:/Jiayi/NISZBridge/commands/current_stop.txt", "E:/Jiayi/NISZBridge/errors/current_stop.txt");
            return rc;
        }

        sprintf(response, "OK %.6f", z);
        WriteFile("E:/Jiayi/NISZBridge/responses/current_stop_response.txt", response, strlen(response) * 2);
        RenameFile("E:/Jiayi/NISZBridge/commands/current_stop.txt", "E:/Jiayi/NISZBridge/processed/current_stop.txt");
        return 1;
    }

    WriteFile("E:/Jiayi/NISZBridge/responses/no_known_command.txt", "no known command", 40);
    return 0;
}
